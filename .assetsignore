# Anything in this list will NOT be uploaded to Cloudflare Pages.
# Syntax is the same as .gitignore.

# Build inputs / dependencies not needed by the served site
node_modules
src/input.css
tailwind.config.js
package.json
package-lock.json

# Repo metadata & docs
.git
.gitignore
.github
README.md
plan.md

# Wrangler / Cloudflare tooling (auto-generated during deploy)
.wrangler
wrangler.toml
wrangler.jsonc

# Editor / OS junk
.DS_Store
.vscode
.idea
*.swp
*.log

# Self
.assetsignore
